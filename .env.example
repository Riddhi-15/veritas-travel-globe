# Copy this file to .env and fill in your keys

# NewsData.io API key — https://newsdata.io
VITE_NEWSDATA_KEY=your_newsdata_api_key_here

# Google Sheets document ID (from the URL: /spreadsheets/d/{ID}/edit)
# The sheet must be published to web (File > Share > Publish to web)
VITE_SHEETS_ID=your_google_sheets_id_here
